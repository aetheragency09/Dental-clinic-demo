<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aether Premium Dental Clinic</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}
body{background:linear-gradient(to bottom,#f8fbff,#eef4ff);scroll-behavior:smooth;transition:0.4s;}
.dark{background:#0f172a;color:white;}

/* NAVBAR */
nav{position:fixed;width:100%;padding:18px 60px;display:flex;justify-content:space-between;align-items:center;z-index:1000;transition:0.4s;}
nav.scrolled{background:white;box-shadow:0 10px 25px rgba(0,0,0,0.05);}
.dark nav.scrolled{background:#1e293b;}
nav h2{font-weight:800;color:#0a3d62;}
.dark nav h2{color:white;}
nav ul{display:flex;gap:30px;list-style:none;}
nav a{text-decoration:none;color:#333;font-weight:500;transition:0.3s;}
.dark nav a{color:white;}
nav a:hover{color:#0a3d62;}
.toggle{cursor:pointer;font-size:20px;}

/* HERO */
.hero{height:100vh;background:url("https://images.unsplash.com/photo-1588776814546-cf61c07c6e97?auto=format&fit=crop&w=1600&q=80") center/cover no-repeat;display:flex;justify-content:center;align-items:center;text-align:center;position:relative;color:white;}
.hero::after{content:"";position:absolute;inset:0;background:rgba(0,0,0,0.6);}
.hero-content{position:relative;z-index:2;max-width:800px;animation:fadeIn 1.5s;}
.hero h1{font-size:48px;font-weight:800;transform:translateY(-30px);animation:slideDown 1s forwards;}
.hero p{margin-top:20px;opacity:0.9;}
.btn{display:inline-block;margin-top:25px;padding:14px 35px;border-radius:40px;background:#0a3d62;color:white;text-decoration:none;font-weight:600;transition:0.3s;}
.btn:hover{transform:translateY(-6px);box-shadow:0 15px 30px rgba(0,0,0,0.3);}

/* SECTIONS */
section{padding:120px 60px;}
.section-title{text-align:center;margin-bottom:50px;}
.section-title h2{font-size:36px;color:#0a3d62;}
.dark .section-title h2{color:white;}

/* SERVICES */
.services{display:flex;gap:30px;flex-wrap:wrap;justify-content:center;}
.card{width:280px;padding:30px;border-radius:20px;background:rgba(255,255,255,0.7);backdrop-filter:blur(15px);transition:0.4s;box-shadow:0 15px 30px rgba(0,0,0,0.08);}
.card:hover{transform:translateY(-12px) rotateX(6deg);box-shadow:0 25px 45px rgba(0,0,0,0.15);}
.dark .card{background:#1e293b;color:white;}

/* PACKAGES / SALES */
.packages{display:flex;flex-wrap:wrap;gap:30px;justify-content:center;}
.package-card{background:rgba(255,255,255,0.7);backdrop-filter:blur(15px);padding:25px;width:260px;border-radius:20px;text-align:center;transition:0.4s;box-shadow:0 15px 30px rgba(0,0,0,0.08);}
.package-card:hover{transform:translateY(-10px);box-shadow:0 25px 45px rgba(0,0,0,0.2);}
.package-card h3{margin-bottom:10px;}
.package-card p{font-size:14px;color:#555;}
.dark .package-card{background:#1e293b;color:white;}

/* GALLERY SLIDER */
.slider-container{position:relative;width:100%;max-width:900px;margin:auto;overflow:hidden;border-radius:20px;}
.slider-track{display:flex;transition:transform 0.6s ease-in-out;}
.slide{min-width:100%;position:relative;}
.slide img{width:100%;border-radius:20px;}
.slider-btn{position:absolute;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.4);color:white;border:none;padding:12px;border-radius:50%;cursor:pointer;transition:0.3s;}
.slider-btn:hover{background:rgba(0,0,0,0.7);}
#prev{left:10px;}#next{right:10px;}
.slider-dots{text-align:center;margin-top:15px;}
.slider-dots span{display:inline-block;width:12px;height:12px;background:#ccc;border-radius:50%;margin:0 5px;cursor:pointer;}
.slider-dots .active{background:#0a3d62;}

/* TESTIMONIALS */
.testimonials{display:flex;flex-wrap:wrap;gap:30px;justify-content:center;}
.testimonial-card{background:rgba(255,255,255,0.7);backdrop-filter:blur(15px);padding:20px;width:280px;border-radius:20px;text-align:center;transition:0.4s;box-shadow:0 15px 30px rgba(0,0,0,0.08);}
.testimonial-card:hover{transform:translateY(-8px);}
.testimonial-card p{font-style:italic;}
.testimonial-card h4{margin-top:10px;font-weight:600;}
.dark .testimonial-card{background:#1e293b;color:white;}

/* TEAM */
.team{display:flex;flex-wrap:wrap;gap:30px;justify-content:center;}
.team-card{background:rgba(255,255,255,0.7);backdrop-filter:blur(15px);padding:20px;width:220px;border-radius:20px;text-align:center;transition:0.4s;box-shadow:0 15px 30px rgba(0,0,0,0.08);}
.team-card img{width:100%;border-radius:50%;margin-bottom:12px;}
.team-card:hover{transform:translateY(-8px);}
.dark .team-card{background:#1e293b;color:white;}

/* COUNTERS */
.counters{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-top:40px;}
.counter{background:rgba(255,255,255,0.7);backdrop-filter:blur(15px);padding:30px;width:180px;border-radius:20px;text-align:center;transition:0.4s;box-shadow:0 15px 30px rgba(0,0,0,0.08);}
.counter h3{font-size:32px;color:#0a3d62;}
.counter p{margin-top:10px;font-weight:500;}
.counter:hover{transform:translateY(-8px);}
.dark .counter{background:#1e293b;color:white;}

/* CONTACT FORM */
form{max-width:500px;margin:auto;}
form input,form textarea,form input[type=date]{width:100%;padding:12px;margin:12px 0;border-radius:12px;border:1px solid #ccc;}
form button{width:100%;padding:14px;border:none;background:#0a3d62;color:white;border-radius:30px;font-weight:600;cursor:pointer;}

/* FOOTER */
footer{background:#0a3d62;color:white;text-align:center;padding:40px 20px;position:relative;}
footer a{color:white;margin:0 10px;font-size:20px;text-decoration:none;transition:0.3s;}
footer a:hover{color:#25D366;}

/* WHATSAPP */
.whatsapp{position:fixed;bottom:25px;right:25px;background:#25D366;color:white;padding:16px;border-radius:50%;font-size:22px;text-decoration:none;box-shadow:0 10px 25px rgba(0,0,0,0.3);transition:0.3s;}
.whatsapp:hover{transform:scale(1.1);}

/* CHATBOT */
.chatbot-btn{position:fixed;bottom:100px;right:25px;background:#0a3d62;color:white;padding:15px;border-radius:50%;cursor:pointer;z-index:999;}
.chatbox{position:fixed;bottom:160px;right:25px;width:300px;background:white;border-radius:15px;box-shadow:0 15px 35px rgba(0,0,0,0.2);display:none;flex-direction:column;}
.chatbox header{background:#0a3d62;color:white;padding:12px;border-radius:15px 15px 0 0;}
.chatbox .messages{padding:10px;height:200px;overflow-y:auto;font-size:14px;}
.chatbox input{border:none;border-top:1px solid #ddd;padding:10px;width:100%;}

.dark .chatbox{background:#1e293b;color:white;}
.dark .chatbox input{background:#334155;color:white;}

/* ANIMATIONS */
@keyframes slideDown{from{transform:translateY(-30px);opacity:0;}to{transform:translateY(0);opacity:1;}}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
.hidden{opacity:0;transform:translateY(60px);transition:all 0.8s ease;}
.show{opacity:1;transform:translateY(0);}
@media(max-width:768px){section{padding:80px 20px;} .hero h1{font-size:34px;}}
</style>
</head>
